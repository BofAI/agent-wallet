{
  "name": "@bankofai/agent-wallet",
  "version": "2.4.0-beta.1",
  "description": "Universal multi-chain secure signing SDK for AI agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "agent-wallet": "./dist/delivery/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && eslint src/ examples/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "prepublishOnly": "pnpm build",
    "publish:beta": "pnpm publish --tag beta --access public",
    "publish:latest": "pnpm publish --access public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "author": "BankOfAI <gummy780j@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/BofAI/agent-wallet",
    "directory": "packages/typescript"
  },
  "homepage": "https://github.com/BofAI/agent-wallet/tree/main/packages/typescript",
  "bugs": "https://github.com/BofAI/agent-wallet/issues",
  "keywords": [
    "wallet",
    "signing",
    "blockchain",
    "evm",
    "tron",
    "agent",
    "mcp",
    "eip712"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@noble/curves": "^1.9.1",
    "bs58check": "^4.0.0",
    "viem": "^2.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tronweb": "^6.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.0.0"
  }
}
